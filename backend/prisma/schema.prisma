datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Vehicle {
  id              String   @id @default(uuid())
  regNumber       String   @unique
  name            String
  model           String
  type            String
  fuelType        String
  maxCapacity     Int
  odometer        Int
  acquisitionCost Decimal  @db.Decimal(15, 2)
  purchaseDate    DateTime @db.Date
  insuranceExpiry DateTime @db.Date
  status          String   @default("Available")
  photoUrl        String?
  documentUrl     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  trips           Trip[]
  maintenance     Maintenance[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@map("vehicles")
}

model Driver {
  id              String   @id @default(uuid())
  name            String
  licenseNumber   String   @unique
  licenseCategory String
  licenseExpiry   DateTime @db.Date
  phone           String
  safetyScore     Int      @default(100)
  status          String   @default("Available")
  experience      String
  tripsCount      Int      @default(0)
  incidentsCount  Int      @default(0)
  rating          Float    @default(5.0)
  avatar          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  trips           Trip[]
  fuelLogs        FuelLog[]

  @@map("drivers")
}

model Trip {
  id            String   @id @default(uuid())
  tripId        String   @unique
  origin        String
  destination   String
  status        String   @default("Scheduled") // Draft, Scheduled, In Progress, Completed, Cancelled
  eta           String?
  distance      String?
  cargo         String
  weight        Int
  priority      String   @default("Normal") // Normal, High, Urgent
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId      String
  driver        Driver   @relation(fields: [driverId], references: [id])

  @@map("trips")
}

model Maintenance {
  id            String   @id @default(uuid())
  maintenanceId String   @unique
  type          String
  category      String
  priority      String   @default("Normal") // Normal, High, Critical
  cost          Decimal  @db.Decimal(15, 2)
  technician    String
  date          DateTime @db.Date
  status        String   @default("Scheduled") // Scheduled, In Progress, Completed, Overdue
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("maintenance")
}

model FuelLog {
  id         String   @id @default(uuid())
  fuelLogId  String   @unique
  liters     Float
  cost       Decimal  @db.Decimal(15, 2)
  date       DateTime @db.Date
  odometer   Int
  station    String
  efficiency String // e.g. "2.8 km/L"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId   String
  driver     Driver   @relation(fields: [driverId], references: [id])

  @@map("fuel_logs")
}

model Expense {
  id          String   @id @default(uuid())
  expenseId   String   @unique
  type        String // Fuel, Maintenance, Toll, Insurance, Repair, Other
  description String
  amount      Decimal  @db.Decimal(15, 2)
  receipt     String
  status      String   @default("Pending") // Pending, Approved, Rejected
  date        DateTime @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fuelLogId   String?  @unique

  // Relationships
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("expenses")
}
