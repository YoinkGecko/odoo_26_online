# PostgreSQL (self-hosted)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transitops?schema=public"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend origin only
FRONTEND_ORIGIN=http://localhost:5173

# Account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
